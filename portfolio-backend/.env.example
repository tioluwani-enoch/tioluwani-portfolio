# Copy this to .env and fill in your values
# NEVER commit .env to git

# Gmail address you'll send FROM (your Gmail)
GMAIL_USER=teolubunmi@gmail.com

# Gmail App Password (NOT your regular password)
# Generate one at: https://myaccount.google.com/apppasswords
# Steps: Google Account → Security → 2-Step Verification → App passwords
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# Email address to RECEIVE contact form submissions (your inbox)
RECIPIENT_EMAIL=teolubunmi@gmail.com

# Port to run the server on
PORT=3001

# Your frontend URL (for CORS) - change this when you deploy
FRONTEND_URL=http://localhost:5173
